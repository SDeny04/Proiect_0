<Window x:Class="Magazin.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Magazin PC — Panou de Control"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="BgDark" Color="#0D1117"/>
        <SolidColorBrush x:Key="BgCard" Color="#161B22"/>
        <SolidColorBrush x:Key="BgCardHover" Color="#1C2333"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#30363D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#58A6FF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#3FB950"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#BC8CFF"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#F0883E"/>
        <SolidColorBrush x:Key="AccentRed" Color="#F85149"/>
        <SolidColorBrush x:Key="AccentTeal" Color="#39D2C0"/>

        <!-- Gradient Brushes -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#58A6FF" Offset="0"/>
            <GradientStop Color="#BC8CFF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#238636" Offset="0"/>
            <GradientStop Color="#2EA043" Offset="1"/>
        </LinearGradientBrush>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C2333"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active Tab Style -->
        <Style x:Key="TabButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Background" Value="#1C2333"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search TextBox Style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Styles -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#111820"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#21262D"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="44"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1C2333"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A2030"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollBar Styles -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER ═══════ -->
        <Border Grid.Row="0" Padding="28,20,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- PC Icon -->
                    <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#58A6FF" Offset="0"/>
                                <GradientStop Color="#BC8CFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🖥️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Magazin PC" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Panou de Control — Administrare Magazin" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="➕ Adaugă Produs"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#238636"
                            Click="BtnAdaugaProdus_Click"
                            Margin="0,0,10,0"/>

                    <Button Content="🔄 Reîncarcă Date"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#30363D" Foreground="{StaticResource TextPrimary}"
                            Click="BtnRefresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ STATS CARDS ═══════ -->
        <Border Grid.Row="1" Padding="28,0,28,16">
            <UniformGrid Columns="4" Rows="1">
                <!-- Total Produse -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12" Margin="0,0,10,0" Padding="20,16">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#30363D"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="PRODUSE" FontSize="11" Foreground="{StaticResource TextSecondary}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtTotalProduse" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}" Margin="0,6,0,0"/>
                        <TextBlock x:Name="TxtStocTotal" Text="Stoc total: 0" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Comenzi -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12" Margin="5,0,5,0" Padding="20,16">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#30363D"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛒" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="COMENZI" FontSize="11" Foreground="{StaticResource TextSecondary}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtTotalComenzi" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreen}" Margin="0,6,0,0"/>
                        <TextBlock x:Name="TxtVenituri" Text="Venituri: 0 RON" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Utilizatori -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12" Margin="5,0,5,0" Padding="20,16">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#30363D"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="UTILIZATORI" FontSize="11" Foreground="{StaticResource TextSecondary}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtTotalUtilizatori" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentPurple}" Margin="0,6,0,0"/>
                        <TextBlock x:Name="TxtAdmini" Text="Admini: 0 | Clienți: 0" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Categorii -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12" Margin="10,0,0,0" Padding="20,16">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#30363D"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏷️" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="CATEGORII" FontSize="11" Foreground="{StaticResource TextSecondary}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtTotalCategorii" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentOrange}" Margin="0,6,0,0"/>
                        <TextBlock x:Name="TxtCategTop" Text="-" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <!-- ═══════ TAB BAR ═══════ -->
        <Border Grid.Row="2" Padding="28,0,28,0">
            <Border Background="{StaticResource BgCard}" CornerRadius="12,12,0,0" Padding="8,8,8,0"
                    BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,1,1,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="BtnTabProduse" Content="📦  Produse"
                                Style="{StaticResource TabButtonActiveStyle}"
                                Click="BtnTabProduse_Click"/>
                        <Button x:Name="BtnTabComenzi" Content="🛒  Comenzi"
                                Style="{StaticResource TabButtonStyle}"
                                Click="BtnTabComenzi_Click"/>
                        <Button x:Name="BtnTabUtilizatori" Content="👥  Utilizatori"
                                Style="{StaticResource TabButtonStyle}"
                                Click="BtnTabUtilizatori_Click"/>
                    </StackPanel>

                    <TextBox Grid.Column="2" x:Name="TxtSearch"
                             Style="{StaticResource SearchBoxStyle}"
                             Width="240" Margin="0,0,4,6"
                             VerticalAlignment="Center"
                             TextChanged="TxtSearch_TextChanged">
                    </TextBox>
                </Grid>
            </Border>
        </Border>

        <!-- ═══════ CONTENT AREA ═══════ -->
        <Border Grid.Row="3" Padding="28,0,28,20">
            <Border Background="{StaticResource BgCard}" CornerRadius="0,0,12,12" Padding="2"
                    BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,1,1">
                <Grid>
                    <!-- Produse DataGrid -->
                    <DataGrid x:Name="GridProduse" Visibility="Visible">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="NUME PRODUS" Binding="{Binding Nume}" Width="1.5*"/>
                            <DataGridTextColumn Header="CATEGORIE" Binding="{Binding CategorieProdus}" Width="130"/>
                            <DataGridTextColumn Header="PREȚ (RON)" Binding="{Binding Pret, StringFormat=N2}" Width="120"/>
                            <DataGridTextColumn Header="OPȚIUNI" Binding="{Binding OptiuniProdus}" Width="2*"/>
                            <DataGridTextColumn Header="STOC" Binding="{Binding Stoc}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Comenzi DataGrid -->
                    <DataGrid x:Name="GridComenzi" Visibility="Collapsed">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="ID CLIENT" Binding="{Binding IdClient}" Width="100"/>
                            <DataGridTextColumn Header="NR. PRODUSE" Binding="{Binding IdProduse.Count}" Width="120"/>
                            <DataGridTextColumn Header="ID-URI PRODUSE" Binding="{Binding ProduseText}" Width="*"/>
                            <DataGridTextColumn Header="TOTAL (RON)" Binding="{Binding Total, StringFormat=N2}" Width="130"/>
                            <DataGridTextColumn Header="DATA" Binding="{Binding DataComenzii, StringFormat=dd/MM/yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Utilizatori DataGrid -->
                    <DataGrid x:Name="GridUtilizatori" Visibility="Collapsed">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="NUME" Binding="{Binding Nume}" Width="*"/>
                            <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="160"/>
                            <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="220"/>
                            <DataGridTextColumn Header="ROL" Binding="{Binding Rol}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty State -->
                    <StackPanel x:Name="PanelEmpty" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Nu există date de afișat" FontSize="16"
                                   Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Adăugați date din consola aplicației" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
