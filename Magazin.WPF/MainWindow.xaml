<Window x:Class="Magazin.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Magazin PC"
        Height="500" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Stil comun pentru Butoane -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <!-- Stil comun pentru TextBlock în meniu/statistici -->
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. Meniu la alegere -->
        <Menu Grid.Row="0" Background="#F0F0F0" Padding="5">
            <MenuItem Header="_Fisier">
                <MenuItem Header="_Adauga Produs" Click="BtnAdaugaProdus_Click"/>
                <MenuItem Header="_Reincarca Date" Click="BtnRefresh_Click"/>
                <Separator/>
                <MenuItem Header="_Iesire" Click="MenuItemIesire_Click"/>
            </MenuItem>
            <MenuItem Header="_Actiuni">
                <MenuItem Header="Schimba la Tab Produse" Click="BtnTabProduse_Click"/>
                <MenuItem Header="Schimba la Tab Comenzi" Click="BtnTabComenzi_Click"/>
                <MenuItem Header="Schimba la Tab Utilizatori" Click="BtnTabUtilizatori_Click"/>
            </MenuItem>
            <MenuItem Header="_Ajutor">
                <MenuItem Header="_Despre aplicatie" Click="MenuItemDespre_Click"/>
            </MenuItem>
        </Menu>

        <!-- HEADER -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,10,10,15">
            <TextBlock Text="Magazin PC - Panou Administrare" FontSize="24" FontWeight="Bold" Margin="0,0,30,0"/>
            <Button Content="Adauga Produs Nou" Click="BtnAdaugaProdus_Click" Background="#cce5ff" FontWeight="Bold"/>
        </StackPanel>

        <!-- STATS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10,0,10,15">
            <StackPanel Margin="0,0,30,0">
                <TextBlock Text="PRODUSE" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="TxtTotalProduse" Text="0" FontSize="16"/>
                <TextBlock x:Name="TxtStocTotal" Text="Stoc total: 0"/>
            </StackPanel>

            <StackPanel Margin="0,0,30,0">
                <TextBlock Text="COMENZI" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="TxtTotalComenzi" Text="0" FontSize="16"/>
                <TextBlock x:Name="TxtVenituri" Text="Venituri: 0"/>
            </StackPanel>

            <StackPanel Margin="0,0,30,0">
                <TextBlock Text="UTILIZATORI" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="TxtTotalUtilizatori" Text="0" FontSize="16"/>
                <TextBlock x:Name="TxtAdmini" Text="Admini: 0 | Clienți: 0"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="CATEGORII" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="TxtTotalCategorii" Text="0" FontSize="16"/>
                <TextBlock x:Name="TxtCategTop" Text="-"/>
            </StackPanel>
        </StackPanel>

        <!-- TAB BAR & SEARCH -->
        <Border Grid.Row="3" Background="#eef2f5" Padding="5" Margin="10,0,10,10" BorderBrush="LightGray" BorderThickness="1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="BtnTabProduse" Content="Produse" Click="BtnTabProduse_Click" FontWeight="Bold"/>
                    <Button x:Name="BtnTabComenzi" Content="Comenzi" Click="BtnTabComenzi_Click"/>
                    <Button x:Name="BtnTabUtilizatori" Content="Utilizatori" Click="BtnTabUtilizatori_Click"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="Cauta dupa:" Margin="0,0,5,0"/>
                    <ComboBox x:Name="CboCriteriuCautare" Width="100" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="CriteriuCautare_Changed" VerticalAlignment="Center" Height="25">
                        <ComboBoxItem Content="General"/>
                        <ComboBoxItem Content="ID"/>
                        <ComboBoxItem Content="Nume/Username"/>
                    </ComboBox>
                    <TextBlock Text="Text:" Margin="0,0,5,0"/>
                    <TextBox x:Name="TxtSearch" Width="150" VerticalAlignment="Center" Height="25" TextChanged="TxtSearch_TextChanged"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="4" Margin="10,0,10,10">
            <DataGrid x:Name="GridProduse" Visibility="Visible" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#f0f0f0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="Nume Produs" Binding="{Binding Nume}" Width="*"/>
                    <DataGridTextColumn Header="Categorie" Binding="{Binding CategorieProdus}"/>
                    <DataGridTextColumn Header="Pret (RON)" Binding="{Binding Pret}"/>
                    <DataGridTextColumn Header="Optiuni" Binding="{Binding OptiuniProdus}" Width="*"/>
                    <DataGridTextColumn Header="Stoc" Binding="{Binding Stoc}"/>
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid x:Name="GridComenzi" Visibility="Collapsed" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#f0f0f0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="ID Client" Binding="{Binding IdClient}"/>
                    <DataGridTextColumn Header="Produse" Binding="{Binding ProduseText}" Width="*"/>
                    <DataGridTextColumn Header="Total (RON)" Binding="{Binding Total}"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataComenzii}"/>
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid x:Name="GridUtilizatori" Visibility="Collapsed" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#f0f0f0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="*"/>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                    <DataGridTextColumn Header="Rol" Binding="{Binding Rol}"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel x:Name="PanelEmpty" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Nu există date de afișat." FontSize="14" Foreground="Gray"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
